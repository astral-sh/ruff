# Python source files

## mdtest_snippet.py

```
 1 | from typing import Protocol, runtime_checkable
 2 | 
 3 | @runtime_checkable
 4 | class MethodProto(Protocol):
 5 |     def method(self, x: int) -> int: ...
 6 | 
 7 | @runtime_checkable
 8 | class AttributeProto(Protocol):
 9 |     method: int
10 | 
11 | class MethodNominal:
12 |     def method(self, x: str) -> None:
13 |         pass
14 | 
15 | class AttributeNominal:
16 |     method: int = 1
17 | 
18 | def check_isinstance(method_nominal: MethodNominal, attribute_nominal: AttributeNominal, obj: object):
19 |     isinstance(method_nominal, MethodProto)  # error: [unsafe-isinstance-narrowing]
20 |     isinstance(method_nominal, AttributeProto)  # error: [unsafe-isinstance-narrowing]
21 |     isinstance(attribute_nominal, MethodProto)  # error: [unsafe-isinstance-narrowing]
22 | 
23 |     isinstance(attribute_nominal, AttributeProto)  # no error: `AttributeNominal <: AttributeProto`
24 |     isinstance(obj, MethodNominal)  # no error: members from `MethodNominal` are missing as attributes
25 |     isinstance(obj, AttributeProto)  # no error: members from `AttributeNominal` are missing as attributes
26 | def check_issubclass():
27 |     issubclass(MethodNominal, MethodProto)  # error: [unsafe-isinstance-narrowing]
28 | @runtime_checkable
29 | class NonDataProtocol(Protocol):
30 |     def method(self) -> int: ...
31 | 
32 | def check_tuple(attribute_nominal: AttributeNominal):
33 |     # error: [unsafe-isinstance-narrowing]
34 |     # error: [unsafe-isinstance-narrowing]
35 |     isinstance(attribute_nominal, (MethodProto, NonDataProtocol))
36 | def check_union(nominal: MethodNominal | int):
37 |     isinstance(nominal, MethodProto)  # error: [unsafe-isinstance-narrowing]
38 | 
39 | def check_union_no_overlap(str_or_int: str | int):
40 |     isinstance(str_or_int, MethodProto)  # no error
41 | from typing import TypeVar
42 | 
43 | T = TypeVar("T")
44 | 
45 | @runtime_checkable
46 | class GenericProto(Protocol[T]):
47 |     def get(self) -> T: ...
48 | 
49 | def check_generic_no_overlap(x: GenericProto[int]):
50 |     isinstance(x, GenericProto)  # no error: `GenericProto[int]` is assignable to `GenericProto`
51 | class BadGenericOverlap:
52 |     get: int  # has `get`, but it's an attribute, not a callable
53 | 
54 | def check_generic_overlap(x: BadGenericOverlap):
55 |     isinstance(x, GenericProto)  # error: [unsafe-isinstance-narrowing]
```

