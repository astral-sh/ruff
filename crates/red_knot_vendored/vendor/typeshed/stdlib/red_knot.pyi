from typing import _SpecialForm

# Special operations
def static_assert(x: object) -> None: ...

# Types
Unknown = object()

# Special forms
Not: _SpecialForm
Intersection: _SpecialForm
TypeOf: _SpecialForm

# Predicates on types
class _IsEquivalentTo[S, T]: ...
class _IsSubtypeOf[S, T]: ...
class _IsAssignableTo[S, T]: ...
class _IsDisjointFrom[S, T]: ...
class _IsFullyStatic[T]: ...
class _IsSingleton[T]: ...
class _IsSingleValued[T]: ...

def is_equivalent_to[S, T](x: S, y: T) -> _IsEquivalentTo[S, T]: ...
def is_subtype_of[S, T](x: S, y: T) -> _IsSubtypeOf[S, T]: ...
def is_assignable_to[S, T](x: S, y: T) -> _IsAssignableTo[S, T]: ...
def is_disjoint_from[S, T](x: S, y: T) -> _IsDisjointFrom[S, T]: ...
def is_fully_static[T](x: T) -> _IsFullyStatic[T]: ...
def is_singleton[T](x: T) -> _IsSingleton[T]: ...
def is_single_valued[T](x: T) -> _IsSingleValued[T]: ...
