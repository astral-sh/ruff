116 | # This one is strange in particular because of the mix of old- and new-style
117 | # generics, but according to the PEP, this is okay "if the class, function, or
118 | # type alias does not use the new syntax." `more_generic` doesn't use the new
119 | # syntax, so it can use T from the module and U from the class scope.
120 | class MixedGenerics[U]:
121 |     def more_generic(u: U, t: T) -> tuple[U, T]:
122 |         return (u, t)
